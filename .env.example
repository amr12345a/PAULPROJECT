# Interactive Brokers connection settings
# Single-route fallback (used when IB_BOT_CONFIGS_JSON is empty)
IB_HOST=127.0.0.1
IB_PORT=4001
IB_CLIENT_ID=101
IB_ACCOUNT=

# Multi-route by webhook id (preferred when using multiple IB Gateways/accounts)
# JSON object keyed by payload.id with host/port/client_id/account per bot.
# Example for two gateways where gateway-2 mirrors gateway-1 bot signals:
IB_BOT_CONFIGS_JSON={"mybot1":{"host":"127.0.0.1","port":4001,"client_id":101,"account":"DU111111"},"mybot2":{"host":"127.0.0.1","port":4001,"client_id":102,"account":"DU111111"},"mybot3":{"host":"127.0.0.1","port":4002,"client_id":201,"account":"DU222222"},"mybot4":{"host":"127.0.0.1","port":4002,"client_id":202,"account":"DU222222"}}

# Optional mirror map to fan out one incoming id to extra route ids.
# Example below means: mybot1 orders are also sent to mybot3, and mybot2 to mybot4.
IB_MIRROR_MAP_JSON={"mybot1":["mybot3"],"mybot2":["mybot4"]}

# Web server settings
HOST=0.0.0.0
PORT=8080

# Trading settings
DEFAULT_EXCHANGE=SMART
DEFAULT_CURRENCY=USD
DEFAULT_ORDER_TYPE=MKT
DEFAULT_QUANTITY=1
DEFAULT_TIF=DAY
DEFAULT_OUTSIDE_RTH=true
ULT_OUTSIDE_RTH=true
ORDER_STATUS_WAIT_SECONDS=2.0
ALLOWED_BOT_IDS=mybot1,mybot2,mybot3,mybot4

# Windows deployment notes:
# - Use deploy_windows.ps1 for installation and optional startup task/firewall setup.
# - Start the app with start_windows.ps1 or by running uvicorn directly.
