# Interactive Brokers connection settings
# Single-route fallback (used when IB_BOT_CONFIGS_JSON is empty)
IB_HOST=127.0.0.1
IB_PORT=4002
IB_CLIENT_ID=101
IB_ACCOUNT=

# Multi-route by webhook id (preferred when using multiple IB Gateways/accounts)
# JSON object keyed by payload.id with host/port/client_id/account per bot.
# Example for two bots/accounts:
IB_BOT_CONFIGS_JSON={"my-bot":{"host":"127.0.0.1","port":4001,"client_id":101,"account":"account1"},"my-bot2":{"host":"127.0.0.1","port":4002,"client_id":102,"account":"account2"}}

# Web server settings
HOST=0.0.0.0
PORT=80

# Trading settings
DEFAULT_EXCHANGE=SMART
DEFAULT_CURRENCY=USD
DEFAULT_ORDER_TYPE=MKT
DEFAULT_QUANTITY=1
DEFAULT_TIF=DAY
DEFAULT_OUTSIDE_RTH=true
ORDER_STATUS_WAIT_SECONDS=2.0
ALLOWED_BOT_IDS=my-bot,my-bot2

# Deploy script settings (used by deploy_ubuntu.sh)
IB_GATEWAY_INSTALLER_URL=https://download2.interactivebrokers.com/installers/ibgateway/latest-standalone/ibgateway-latest-standalone-linux-x64.sh
IB_GATEWAY_LAUNCHER=
# Optional: start one IB Gateway service per bot ID (comma-separated)
# Example: IB_GATEWAY_IDS=my-bot1,my-bot2
IB_GATEWAY_IDS=my-bot,my-bot2
VNC_PASSWORD=change-me-now
VNC_GEOMETRY=1920x1080
VNC_DEPTH=24
