[Unit]
Description=IBKR Trade Executor
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/ib-trade-executor
EnvironmentFile=/opt/ib-trade-executor/.env
ExecStart=/opt/ib-trade-executor/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
