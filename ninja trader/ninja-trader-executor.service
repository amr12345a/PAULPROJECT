[Unit]
Description=NinjaTrader Trade Executor
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/ninja-trader-executor
EnvironmentFile=/opt/ninja-trader-executor/.env
ExecStart=/opt/ninja-trader-executor/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 80
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
