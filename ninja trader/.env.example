# NinjaTrader Strategy Bridge configuration
# NT_STRATEGY_URL: Address of your NinjaScript signal receiver strategy HTTP endpoint
# NT_API_KEY: Optional bearer token if your strategy requires authentication
# NT_ACCOUNT: NinjaTrader account name (e.g., 'Sim101', 'Live01')
# NT_INSTRUMENT_PREFIX: Optionally prepend to ticker (e.g., set 'Z2' to convert 'ES' -> 'ES Z2')
NT_STRATEGY_URL=http://127.0.0.1:8000/api/v1/signal
NT_API_KEY=
NT_ACCOUNT=Sim101
NT_INSTRUMENT_PREFIX=

# Web server settings
HOST=0.0.0.0
PORT=80

# Trading settings
DEFAULT_ORDER_TYPE=Market
DEFAULT_QUANTITY=1
ORDER_STATUS_WAIT_SECONDS=1.0
NT_ORDER_SIGNAL_MODE=market
NT_HEARTBEAT_ENABLED=true

# VNC settings for credential entry via desktop GUI
VNC_PASSWORD=change-me-now
VNC_GEOMETRY=1920x1080
VNC_DEPTH=24

# NinjaTrader installer (used by deploy_ubuntu.sh auto-launch)
# IMPORTANT: this must be a direct .msi or .exe link, not a webpage URL.
# Example: https://example.com/NinjaTraderInstaller.msi
NT_INSTALLER_URL=
NT_DIR=/opt/ninjatrader
